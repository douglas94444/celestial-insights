# Cliente (prefixo VITE_ — embutido no bundle; nunca uses VITE_ para chaves secretas de IA, Resend ou service role)
# AstroMap (produção): https://fxcoxnqqjgvqfukasfjb.supabase.co — substitua YOUR_PROJECT no teu clone se usar outro Supabase
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key

# Opcional: rodapé «Criado em @…» no cartão Momento / Instagram (com ou sem @)
VITE_APP_INSTAGRAM_HANDLE=

# Opcional: URL no cartão / legenda «Monte o seu mapa» (fallback: origin do browser)
VITE_APP_SHARE_URL=

# Opcional: Meta Pixel (Facebook) — ID público; PageView no cliente e em navegações SPA
VITE_META_PIXEL_ID=

# Opcional: Meta Conversions API — token de sistema (só servidor; nunca prefixo VITE_). Colar o token completo no deploy / .env local; não commitar.
META_CAPI_ACCESS_TOKEN=
# Mesmo ID numérico do pixel que em VITE_META_PIXEL_ID (CAPI no servidor precisa disto sem depender do bundle do cliente)
META_PIXEL_ID=

# Servidor (TanStack Start / Workers — não expor ao cliente)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_anon_key

# Deploy Cloudflare Workers (`npm run deploy:worker`) — Wrangler em modo não-interativo / CI
CLOUDFLARE_API_TOKEN=

# Opcional: operações com role de serviço (ex.: exclusão de conta, cron digest)
SUPABASE_SERVICE_ROLE_KEY=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# URL pública do site (cron Momento/digest — link clicável nos emails; sem prefixo VITE_)
APP_PUBLIC_URL=https://seu-dominio.com

# SyncPay (Pix cash-in) — só servidor; ver docs/operacao-ambiente.md
# URL base da API Partner (só o host, sem /api/partner/v1 e sem barra final), ex.: https://api.exemplo.com
SYNCPAY_API_BASE_URL=
SYNCPAY_CLIENT_ID=
SYNCPAY_CLIENT_SECRET=
# Segredo na query string do webhook (?token=...) e na Edge Function syncpay-webhook
SYNCPAY_WEBHOOK_TOKEN=

# Mercado Pago — ver docs/operacao-ambiente.md
# Token de acesso (produção ou teste; credenciais de teste costumam começar por TEST-)
MERCADOPAGO_ACCESS_TOKEN=
# Segredo na query do webhook (?token=...) na Edge Function mercadopago-webhook
MERCADOPAGO_WEBHOOK_TOKEN=
# Chave pública (Checkout Transparente — Card Payment Brick no browser). Preferir VITE_ no build do cliente.
VITE_MERCADOPAGO_PUBLIC_KEY=
# Opcional no Worker: mesma chave pública se import.meta.env não estiver disponível no runtime
MERCADOPAGO_PUBLIC_KEY=

# Digest automático de trânsitos — POST JSON com { "cronSecret": "..." }
# Segredo longo e aleatório; sem prefixo VITE_. Se definido, só estes IPs podem chamar o cron (CSV). Cloudflare: usar CF-Connecting-IP.
# TRANSIT_DIGEST_CRON_ALLOWED_IPS=
# Usado pelo Worker (`processTransitDigestCronFn`) e deve coincidir com o secret na Edge Function Supabase (`transit-digest-cron`), se usar ambos (evite dois crons ativos).
TRANSIT_DIGEST_CRON_SECRET=

# IA — interpretações personalizadas (só servidor; nunca prefixo VITE_)
# Use ANTHROPIC_API_KEY ou OPENAI_API_KEY. AI_PROVIDER força um dos dois quando ambos existem.
AI_PROVIDER=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_ANTHROPIC_MODEL=
AI_OPENAI_MODEL=
AI_REQUEST_TIMEOUT_MS=
AI_MAX_RESPONSE_CHARS=
# Gate e quotas (ver docs/operacao-ambiente.md)
AI_INTERPRETATION_REQUIRE_PREMIUM=
AI_INTERPRETATION_FREE_TRIES_PER_MONTH=
AI_INTERPRETATION_MAX_PER_24H_FREE=
AI_INTERPRETATION_MAX_PER_24H_PREMIUM=

# Pré-visualização de mapa (calculateChartFn): máximo de chamadas por utilizador por hora (predefinição 90). Requer migração chart_preview_calc_events.
CALCULATE_CHART_MAX_PER_USER_PER_HOUR=
